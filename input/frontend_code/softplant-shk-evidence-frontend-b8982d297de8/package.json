{
  "name": "evidence-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run lint && vite --host --force",
    "dev": "npm run lint && vite --host --force",
    "kill-port": "lsof -ti:5173 | xargs kill -9 || true",
    "dev:demo": "npm run lint && VITE_DEMO_MODE=true vite --host --force",
    "build": "tsc -b && GENERATE_SOURCEMAP=false vite build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.{tsx,js,ts}\" --fix --max-warnings 0",
    "preview": "vite preview",
    "report": "npx vite-bundle-visualizer",
    "cypress:open": "NODE_ENV=development npx cypress open",
    "cypress": "NODE_ENV=development npx cypress run",
    "nextui:doctor": "npx nextui-cli@latest doctor",
    "nextui:env": "npx nextui-cli@latest env",
    "git": "git log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit",
    "send": "npm run lint && npm run check-backend && node send-notion.js",
    "check-backend": "curl -s -f localhost:8080/health > /dev/null || (echo '디버깅을 위해서 로컬 백엔드 port 8080가 열려있지 않습니다. 프로젝트를 실행하기 전 디버깅을 위해서 로컬 백엔드를 실행시켜주세요.' && exit 1)",
    "prepare": "husky install"
  },
